# ===== 数据库 =====
DATABASE_URL=postgresql+asyncpg://gameuser:gamepass@localhost:5432/gamedb
POSTGRES_DB=gamedb
POSTGRES_USER=gameuser
POSTGRES_PASSWORD=gamepass

# ===== Redis =====
REDIS_URL=redis://localhost:6379/0

# ===== AI 配置（统一接口） =====
# 提供商类型：openai / anthropic / local / custom
AI_PROVIDER=openai

# API 密钥和地址
AI_API_KEY=sk-your-api-key-here
AI_BASE_URL=https://api.openai.com/v1

# 模型选择
AI_MODEL_DEFAULT=gpt-4o-mini       # 评估、压缩等低成本任务
AI_MODEL_PREMIUM=gpt-4o            # 叙事生成等高质量任务

# Claude 配置（可选，仅 AI_PROVIDER=anthropic 时需要）
ANTHROPIC_API_KEY=

# 备用 API（可选，用于故障转移）
AI_FALLBACK_API_KEY=
AI_FALLBACK_BASE_URL=
AI_FALLBACK_MODEL=

# ===== JWT =====
JWT_SECRET_KEY=your-super-secret-key-change-this
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# ===== Firebase（可选） =====
FIREBASE_CREDENTIALS_PATH=./firebase.json

# ===== Sentry（可选） =====
SENTRY_DSN=

# ===== 应用 =====
APP_ENV=development
APP_DEBUG=true
APP_PORT=8000

# ===== 前端 =====
NEXT_PUBLIC_API_URL=http://localhost:8000

# ===== 速率限制 =====
RATE_LIMIT_PER_MINUTE=60
